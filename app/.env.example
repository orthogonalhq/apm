# Database (Neon — set by Vercel integration as REGISTRY_* prefix)
REGISTRY_POSTGRES_URL=
REGISTRY_POSTGRES_URL_NON_POOLING=

# GitHub (PAT for higher rate limits on code search)
GITHUB_TOKEN=

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# App URL (http://localhost:3000 for local dev)
NEXT_PUBLIC_URL=

# Admin (comma-separated publisher UUIDs)
ADMIN_PUBLISHER_IDS=

# Anthropic API key for automated package classification (optional — skip if classifying via Claude Code)
APM_CLASSIFIER_API_KEY=

# Resend (transactional email for namespace approvals/rejections)
RESEND_API_KEY=

# Cron authentication
CRON_SECRET=
